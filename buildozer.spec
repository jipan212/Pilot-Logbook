[app]

# Nama aplikasi
title = Pilot Logbook

# Nama package (jangan pakai spasi)
package.name = pilotlogbook
package.domain = irvan.dev

# Lokasi source code
source.dir = .
source.include_exts = py,png,jpg,kv,db

# Versi aplikasi
version = 0.1

# Library yang dipakai
requirements = python3,kivy,sqlite3,reportlab

# Orientasi layar
orientation = portrait

# Fullscreen
fullscreen = 0


[buildozer]

# Level log
log_level = 2

# Jangan ubah ini dulu
warn_on_root = 1